# or the simpler single-TURN form below.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
NEXT_PUBLIC_STREAM_RELAY_VIDEO_BITRATE=8000000
